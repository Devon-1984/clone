---
import Spacer from "./Spacer.astro";
const { images, currentPage } = Astro.props;

const allCategories = [
  { key: "retailers", title: "Fashion", href: "/retailers?category=Fashion" },
  {
    key: "retailers",
    title: "Food + Drink",
    href: "/retailers?category=Food%20%2B%20Drink",
  },
  {
    key: "retailers",
    title: "Health + Beauty",
    href: "/retailers?category=Health%20%2B%20Beauty",
  },
  {
    key: "retailers",
    title: "Lifestyle + Design",
    href: "/retailers?category=Lifestyle%20%2B%20Design",
  },
  { key: "stay", title: "Stay", href: "/stay" },
  { key: "news", title: "News", href: "/news" },
  { key: "events", title: "Events", href: "/events" },
  { key: "giftcard", title: "Gift Card", href: "/gift-card" },
];

// Page-nav mode: show 3 cards (Retailers, News, Events, Gift Card minus current page)
const pageCards = [
  { key: "retailers", title: "Retailers", href: "/retailers", imageIndex: 0 },
  { key: "news", title: "News", href: "/news", imageIndex: 5 },
  { key: "giftcard", title: "Gift Card", href: "/gift-card", imageIndex: 7 },
  { key: "events", title: "Events", href: "/events", imageIndex: 6 },
];

const isNavMode = !!currentPage;
const visibleCards = isNavMode
  ? pageCards.filter((c) => c.key !== currentPage)
  : null;
const categories = isNavMode ? visibleCards : allCategories;
const cardItems = isNavMode
  ? visibleCards.map((c) => images[c.imageIndex])
  : images;
---

{isNavMode ? <div class="h-25 border-t border-[#0000004d]" /> : <Spacer />}
<section class:list={["p-5", { "nav-mode": isNavMode }]}>
  <!-- Centered hover label overlay (full grid only) -->
  {
    !isNavMode && (
      <div class="hover-labels">
        {categories.map((cat) => (
          <span class="hover-label">{cat.title}</span>
        ))}
      </div>
    )
  }

  <div
    class:list={[
      "grid",
      isNavMode
        ? "grid-cols-3 min-[900px]:gap-[20%] gap-11 max-w-[1200px] mx-auto"
        : "grid-cols-3 min-[901px]:grid-cols-4 min-[901px]:gap-y-[150px] min-[901px]:gap-x-[17.5%] max-[900px]:gap-[45px]",
    ]}
  >
    {
      cardItems.map((item, i) => (
        <article class="card">
          <a href={categories[i].href} class="block">
            <p class="text-sm tracking-widest">{categories[i].title}</p>
            <div class="aspect-[220/290] overflow-hidden">
              <img
                src={item.url}
                alt={categories[i].title}
                class="w-full h-full object-cover"
              />
            </div>
          </a>
        </article>
      ))
    }
  </div>
</section>
{isNavMode ? <div class="h-25 border-b border-[#0000004d]" /> : <Spacer />}

<style>
  section {
    position: relative;
  }

  .hover-labels {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    z-index: 10;
  }

  .hover-label {
    position: absolute;
    letter-spacing: -1px;
    font-size: 60px;
    line-height: 1.1;
    text-align: center;
    opacity: 0;
    transition: opacity 0.5s;
  }

  .card {
    transition: all 0.5s;
  }

  /* dim/desaturate/blur all non-hovered cards when any is hovered */
  section:has(.card:hover) .card:not(:hover) {
    filter: blur(2px);
    opacity: 0.2;
  }

  /* show the matching label for each hovered card */
  section:has(.card:nth-child(1):hover) .hover-label:nth-child(1) {
    opacity: 1;
  }
  section:has(.card:nth-child(2):hover) .hover-label:nth-child(2) {
    opacity: 1;
  }
  section:has(.card:nth-child(3):hover) .hover-label:nth-child(3) {
    opacity: 1;
  }
  section:has(.card:nth-child(4):hover) .hover-label:nth-child(4) {
    opacity: 1;
  }
  section:has(.card:nth-child(5):hover) .hover-label:nth-child(5) {
    opacity: 1;
  }
  section:has(.card:nth-child(6):hover) .hover-label:nth-child(6) {
    opacity: 1;
  }
  section:has(.card:nth-child(7):hover) .hover-label:nth-child(7) {
    opacity: 1;
  }
  section:has(.card:nth-child(8):hover) .hover-label:nth-child(8) {
    opacity: 1;
  }
</style>
