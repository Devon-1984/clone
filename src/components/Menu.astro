---

---

<nav class="menu-wrapper">
  <!-- ── Desktop bar ── -->
  <div class="menu-bar">
    <div class="prefix-slot">
      <slot name="prefix" />
    </div>

    <div class="nav-links">
      <button class="menu-item">Retailers</button>
      <a class="menu-item" href="/events">Events</a>
      <a class="menu-item" href="/news">News</a>
      <a class="menu-item" href="/sign-up">Sign up</a>
      <a class="menu-item" href="/gift-card">Gift Card</a>
    </div>

    <div class="nav-right">
      <div class="desktop-actions">
        <button class="menu-item">Search</button>
        <button class="menu-item">Cart</button>
      </div>

      <!-- 2-line hamburger (mobile only) -->
      <button class="hamburger-btn" aria-label="Open Menu" aria-expanded="false">
        <svg width="26" height="16" viewBox="0 0 26 16" fill="none" xmlns="http://www.w3.org/2000/svg">
          <line x1="0" y1="1" x2="26" y2="1" stroke="currentColor" stroke-width="1.5"/>
          <line x1="0" y1="15" x2="26" y2="15" stroke="currentColor" stroke-width="1.5"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- ── Full-screen mobile overlay ── -->
  <div class="mobile-overlay" aria-hidden="true">
    <div class="overlay-header">
      <div class="overlay-logo">
        <slot name="prefix" />
      </div>
      <button class="close-btn" aria-label="Close Menu">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
          <line x1="1" y1="1" x2="19" y2="19" stroke="currentColor" stroke-width="1.5"/>
          <line x1="19" y1="1" x2="1" y2="19" stroke="currentColor" stroke-width="1.5"/>
        </svg>
      </button>
    </div>

    <nav class="overlay-nav">
      <button class="overlay-item">Retailers</button>
      <a class="overlay-item">Events</a>
      <a class="overlay-item">News</a>
      <a class="overlay-item">Sign up</a>
      <a class="overlay-item">Gift Card</a>
      <a class="overlay-item">Search</a>
      <a class="overlay-item">Cart</a>
    </nav>
  </div>
</nav>

<style>
  /* ── Mobile-first base: hamburger visible, desktop nav hidden ── */
  .menu-bar {
    display: flex;
    align-items: center;
  }

  .prefix-slot {
    flex: 0 0 auto;
  }

  .nav-links {
    display: none;
  }

  .nav-right {
    margin-left: auto;
    display: flex;
    align-items: center;
  }

  .desktop-actions {
    display: none;
  }

  .hamburger-btn {
    display: flex;
    align-items: center;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    line-height: 0;
    color: inherit;
  }

  /* ── Desktop: show nav, hide hamburger ── */
  @media (min-width: 901px) {
    .prefix-slot {
      width: 25%;
    }

    .nav-links {
      display: flex !important;
      width: 50%;
      flex-shrink: 0;
      gap: 1.25rem;
      font-size: 12px;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      align-items: center;
      justify-content: flex-start;
    }

    .nav-right {
      width: 25%;
      margin-left: 0;
      justify-content: flex-end;
    }

    .desktop-actions {
      display: flex !important;
      gap: 1.25rem;
      font-size: 12px;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      align-items: center;
    }

    .hamburger-btn {
      display: none !important;
    }

    .mobile-overlay {
      display: none !important;
    }
  }

  /* ── Shared menu-item style (desktop nav) ── */
  .menu-item {
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    font-size: 12px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    text-decoration: none;
    color: inherit;
    display: inline-flex;
    align-items: center;
    white-space: nowrap;
  }

  .menu-item::before {
    content: "";
    background-color: #fff;
    width: 6px;
    height: 6px;
    margin-bottom: 1px;
    margin-right: 7.5px;
    display: inline-block;
    flex-shrink: 0;
  }

  .menu-item:hover::before {
    animation: blink-black 0.5s step-start infinite;
  }

  @keyframes blink-black {
    0%, 100% { background-color: #000; }
    50%       { background-color: #fff; }
  }

  /* ── Full-screen overlay ── */
  .mobile-overlay {
    position: fixed;
    inset: 0;
    z-index: 100;
    background: #fff;
    transform: translateX(100%);
    transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    overflow-y: auto;
    display: flex;
    flex-direction: column;
  }

  .mobile-overlay.is-open {
    transform: translateX(0);
  }

  .overlay-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.25rem;
    border-bottom: 1px solid #e5e5e5;
  }

  .overlay-logo {
    display: flex;
    align-items: center;
  }

  .close-btn {
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    line-height: 0;
    color: inherit;
  }

  .overlay-nav {
    display: flex;
    flex-direction: column;
    gap: 45px;
    padding: 2rem 1.25rem;
  }

  .overlay-item {
    background: none;
    border: none;
    border-bottom: 1px solid #e5e5e5;
    padding-bottom: 1rem;
    cursor: pointer;
    font-size: 12px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    text-decoration: none;
    color: inherit;
    text-align: left;
    display: block;
    width: 100%;
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>('.menu-wrapper').forEach((wrapper) => {
    const hamburger = wrapper.querySelector<HTMLButtonElement>('.hamburger-btn');
    const closeBtn  = wrapper.querySelector<HTMLButtonElement>('.close-btn');
    const overlay   = wrapper.querySelector<HTMLElement>('.mobile-overlay');

    if (!hamburger || !overlay) return;

    const open = () => {
      overlay.classList.add('is-open');
      overlay.setAttribute('aria-hidden', 'false');
      hamburger.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
    };

    const close = () => {
      overlay.classList.remove('is-open');
      overlay.setAttribute('aria-hidden', 'true');
      hamburger.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    };

    hamburger.addEventListener('click', open);
    closeBtn?.addEventListener('click', close);

    // close on Escape
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') close();
    });
  });
</script>
