---
const { image } = Astro.props;
---

<section class="relative h-[150vh] overflow-clip">
  <!-- Background: scale up slightly for zoomed-in look, overflow-hidden clips the edges -->
  <img
    class="absolute inset-0 w-full h-full object-cover scale-[1.15] origin-center"
    src={image.url}
    alt=""
  />

  <!-- Sticky text — locks at top-0 once section hits viewport top -->
  <div class="sticky h-[60vh] z-10 text-white flex flex-col p-5" style="top: var(--menu-h)">

    <!-- Top row: date + square + title all on one line (left), event info (right) -->
    <div class="flex justify-between items-start w-full">

      <!-- Left: date ■ title -->
      <div class="flex items-center gap-2 text-xs tracking-widest">
        <span class="font-bold">March 19, 2026</span>
        <span class="w-[6px] h-[6px] bg-white inline-block flex-shrink-0"></span>
        <span>James St Up Late 2026</span>
      </div>

      <!-- Right: event info panel -->
      <div class="flex flex-col items-start gap-3 max-w-[200px]">
        <div class="w-20 h-20 rounded-full bg-yellow-400"></div>
        <p class="text-sm leading-snug">High glamour and even higher spirits.</p>
        <a
          href="/events/james-st-up-late-2026"
          class="text-xs flex items-center gap-2"
        >
          <span class="w-[6px] h-[6px] bg-white inline-block flex-shrink-0"></span>
          Discover Now
        </a>
      </div>

    </div>

    <!-- Big heading pushed to bottom -->
    <a
      href="/events/james-st-up-late-2026"
      class="mt-auto text-center font-serif text-[clamp(2.5rem,8vw,7rem)] leading-none"
    >
      James St Up Late 2026
    </a>

  </div>
</section>
